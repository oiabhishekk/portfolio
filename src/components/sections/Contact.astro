---
import { personalInfo } from '../../config';
---
<section id="contact" class="min-h-screen pt-20 pb-10 px-8 flex flex-col justify-center max-w-5xl mx-auto relative">
  
  <div class="bg-bg-card/50 backdrop-blur-md rounded-2xl shadow-xl p-8 md:p-12 border border-border/50 relative overflow-hidden">
    
    <!-- Decorative dashed accent -->
    <div class="absolute top-6 left-6 w-12 h-12 border-t-2 border-l-2 border-dashed border-primary/40 rounded-tl-md"></div>
    <div class="absolute top-4 right-4 text-text-muted/30 text-xl"><i class="fa-solid fa-expand"></i></div>

    <div class="mb-12 text-center relative z-10">
      <div class="text-text-muted flex items-center justify-center gap-2 mb-2 font-mono text-sm">
        <i class="fa-solid fa-cubes"></i>
        <span>Don't hesitate to</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold font-['Orbitron']">
        <span class="text-primary">Contact</span> <span class="text-text-main">Me</span>
      </h2>
    </div>

    <div class="mb-8 relative z-10">
      <h3 class="text-xl font-bold mb-6 flex items-center gap-3">
        <span class="text-primary text-2xl leading-none -mt-1">|</span> 
        <span class="text-text-main">Send me a <span class="text-primary">message</span></span>
      </h3>

      <form id="contact-form" action="https://formsubmit.co/abhiiiworks@gmail.com" method="POST" class="flex flex-col gap-6">
        <input type="hidden" name="_template" value="table">
        <input type="hidden" name="_subject" value="New message from your portfolio!">
        <input type="hidden" name="_captcha" value="false">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          
          <!-- Left Column -->
          <div class="flex flex-col gap-4">
            <div class="flex rounded-md overflow-hidden bg-bg-card border border-border/50 focus-within:border-primary/50 transition-colors shadow-sm">
              <div class="bg-border/30 px-4 flex items-center justify-center border-r border-border/50 w-14 text-text-main">
                <i class="fa-solid fa-user-pen text-sm"></i>
              </div>
              <input type="text" name="name" placeholder="Name *" class="w-full bg-transparent py-3 px-4 text-text-main placeholder-text-muted focus:outline-none text-sm" required />
            </div>

            <div class="flex rounded-md overflow-hidden bg-bg-card border border-border/50 focus-within:border-primary/50 transition-colors shadow-sm">
              <div class="bg-border/30 px-4 flex items-center justify-center border-r border-border/50 w-14 text-text-main">
                <i class="fa-solid fa-envelope text-sm"></i>
              </div>
              <input type="email" name="email" placeholder="E-mail *" class="w-full bg-transparent py-3 px-4 text-text-main placeholder-text-muted focus:outline-none text-sm" required />
            </div>

            <div class="flex rounded-md overflow-hidden bg-bg-card border border-border/50 focus-within:border-primary/50 transition-colors shadow-sm">
              <div class="bg-border/30 px-4 flex items-center justify-center border-r border-border/50 w-14 text-text-main">
                <i class="fa-solid fa-pen-to-square text-sm"></i>
              </div>
              <input type="text" name="subject" placeholder="Subject *" class="w-full bg-transparent py-3 px-4 text-text-main placeholder-text-muted focus:outline-none text-sm" required />
            </div>
          </div>

          <!-- Right Column -->
          <div class="flex flex-col h-full">
            <div class="flex h-full min-h-[160px] rounded-md overflow-hidden bg-bg-card border border-border/50 focus-within:border-primary/50 transition-colors shadow-sm">
              <textarea name="message" placeholder="Message *" class="w-full h-full bg-transparent p-4 text-text-main placeholder-text-muted focus:outline-none resize-none text-sm" required></textarea>
            </div>
          </div>
          
        </div>

        <div class="flex justify-center md:justify-end mt-2 md:-mt-2 relative z-10 md:-mr-4">
          <button id="submit-btn" type="submit" class="bg-primary text-bg-card font-['Orbitron'] font-bold px-8 py-3 rounded-full hover:bg-opacity-90 transition-all flex items-center justify-center gap-3 shadow-[0_4px_14px_rgba(43,122,156,0.3)] uppercase tracking-wide text-sm md:w-auto w-full md:absolute md:top-0">
            <i class="fa-solid fa-envelope"></i>
            <span>SEND MESSAGE</span>
          </button>
        </div>
      </form>
    </div>

    <div class="mt-16 relative z-10">
      <h3 class="text-xl font-bold mb-6 flex items-center gap-3">
        <span class="text-primary text-2xl leading-none -mt-1">|</span> 
        <span class="text-text-main">Or if you <span class="text-primary">prefer...</span></span>
      </h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        
        <a href={`tel:${personalInfo.phone.replace(/\s+/g, '')}`} class="flex rounded-md overflow-hidden bg-bg-card border border-border/50 hover:border-primary/50 transition-colors shadow-sm group">
          <div class="bg-border/30 px-4 py-4 flex items-center justify-center border-r border-border/50 w-16 text-text-main group-hover:text-primary transition-colors">
            <i class="fa-solid fa-phone text-xl"></i>
          </div>
          <div class="p-3 px-4 flex flex-col justify-center">
            <h4 class="font-bold text-text-main text-sm mb-1">Phone</h4>
            <p class="text-xs text-primary leading-relaxed font-mono">{personalInfo.phone}</p>
          </div>
        </a>

        <a href={`mailto:${personalInfo.email}`} class="flex rounded-md overflow-hidden bg-bg-card border border-border/50 hover:border-primary/50 transition-colors shadow-sm group">
          <div class="bg-border/30 px-4 py-4 flex items-center justify-center border-r border-border/50 w-16 text-text-main group-hover:text-primary transition-colors">
            <i class="fa-solid fa-envelope text-xl"></i>
          </div>
          <div class="p-3 px-4 flex flex-col justify-center">
            <h4 class="font-bold text-text-main text-sm mb-1">E-mail</h4>
            <p class="text-xs text-primary leading-relaxed font-mono">{personalInfo.email}</p>
          </div>
        </a>

        <a href={`https://wa.me/${personalInfo.whatsapp}`} target="_blank" class="flex rounded-md overflow-hidden bg-bg-card border border-border/50 hover:border-primary/50 transition-colors shadow-sm group">
          <div class="bg-border/30 px-4 py-4 flex items-center justify-center border-r border-border/50 w-16 text-text-main group-hover:text-primary transition-colors">
            <i class="fa-brands fa-whatsapp text-xl"></i>
          </div>
          <div class="p-3 px-4 flex flex-col justify-center">
            <h4 class="font-bold text-text-main text-sm mb-1">WhatsApp</h4>
            <p class="text-xs text-primary leading-relaxed font-mono">@{personalInfo.firstName}</p>
          </div>
        </a>

        <a href={personalInfo.linkedinUrl} target="_blank" class="flex rounded-md overflow-hidden bg-bg-card border border-border/50 hover:border-primary/50 transition-colors shadow-sm group">
          <div class="bg-border/30 px-4 py-4 flex items-center justify-center border-r border-border/50 w-16 text-text-main group-hover:text-primary transition-colors">
            <i class="fa-brands fa-linkedin text-xl"></i>
          </div>
          <div class="p-3 px-4 flex flex-col justify-center">
            <h4 class="font-bold text-text-main text-sm mb-1">LinkedIn</h4>
            <p class="text-xs text-primary leading-relaxed font-mono">{personalInfo.linkedinUsername}</p>
          </div>
        </a>

      </div>
    </div>
  </div>

</section>
