---
import { skills } from '../../config';

const allCount = skills.length;
const langCount = skills.filter(s => s.category === 'Language').length;
const toolCount = skills.filter(s => s.category === 'Tool').length;
const libCount = skills.filter(s => s.category === 'Library').length;
const dbCount = skills.filter(s => s.category === 'Database').length;
---
<section id="skills" class="min-h-screen py-20 px-8 flex flex-col justify-center max-w-5xl mx-auto">
  <div class="mb-12 text-center">
    <div class="text-text-muted flex items-center justify-center gap-2 mb-2 font-mono text-sm">
      <i class="fa-solid fa-layer-group"></i>
      <span>Explore</span>
    </div>
    <h2 class="text-4xl md:text-5xl font-bold">
      My <span class="text-primary">Tech Stack</span>
    </h2>
  </div>

  <div class="flex flex-wrap justify-center gap-4 mb-12">
    <button class="filter-btn btn-active px-6 py-2.5 rounded-lg text-sm transition-all" data-filter="All">All ({allCount})</button>
    <button class="filter-btn bg-bg-card text-text-muted hover:text-primary px-6 py-2.5 rounded-lg text-sm transition-all" data-filter="Language">Languages ({langCount})</button>
    <button class="filter-btn bg-bg-card text-text-muted hover:text-primary px-6 py-2.5 rounded-lg text-sm transition-all" data-filter="Tool">Tools ({toolCount})</button>
    <button class="filter-btn bg-bg-card text-text-muted hover:text-primary px-6 py-2.5 rounded-lg text-sm transition-all" data-filter="Library">Libraries ({libCount})</button>
    <button class="filter-btn bg-bg-card text-text-muted hover:text-primary px-6 py-2.5 rounded-lg text-sm transition-all" data-filter="Database">Databases ({dbCount})</button>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4" id="tech-grid">
    {skills.map((skill) => (
      <div class="skill-card bg-bg-card border border-border/50 rounded-xl flex flex-col items-center justify-center p-6 gap-4 hover:border-primary hover:-translate-y-1 transition-all duration-300 cursor-default group aspect-square shadow-sm" data-category={skill.category}>
        <img src={skill.icon} alt={skill.name} class={`w-14 h-14 object-contain group-hover:scale-110 transition-transform duration-300 ${skill.invert ? 'auto-invert' : ''}`} />
        <span class="text-sm font-medium text-text-muted group-hover:text-text-main transition-colors text-center">{skill.name}</span>
      </div>
    ))}
  </div>
</section>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const skillCards = document.querySelectorAll('.skill-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Remove active state from all
      filterBtns.forEach(b => {
        b.classList.remove('btn-active');
        b.classList.add('text-text-muted', 'bg-bg-card');
      });
      
      // Add active state to clicked
      btn.classList.remove('text-text-muted', 'bg-bg-card');
      btn.classList.add('btn-active');

      const filter = btn.getAttribute('data-filter');
      
      skillCards.forEach(card => {
        const category = card.getAttribute('data-category');
        if (filter === 'All' || filter === category) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
